APP_NAME=FacturaCO
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=America/Bogota
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Base de datos ──────────────────────────────────────────────────────────
# Local: PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=facturaco
DB_USERNAME=postgres
DB_PASSWORD=
DB_CHARSET=utf8
DB_SCHEMA=public

# Railway (producción): sobrescribe DB_* con DATABASE_URL
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── Cache / Session / Queue ────────────────────────────────────────────────
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# Local: sync | Producción: database (Railway ya lo usa)
QUEUE_CONNECTION=database

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ─── Redis (opcional, para cache/queue en producción) ───────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Correo ─────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="facturacion@tudominio.co"
MAIL_FROM_NAME="FacturaCO"

# ─── AWS S3 (backups, adjuntos) ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Wompi (pagos en línea) ──────────────────────────────────────────────────
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=
WOMPI_ENV=sandbox

# ─── DIAN (facturación electrónica) ─────────────────────────────────────────
# DIAN_AMBIENTE=habilitacion        # habilitacion | produccion
# DIAN_CERTIFICADO_PATH=/ruta/cert.p12
# DIAN_CERTIFICADO_PASSWORD=
# DIAN_SOFTWARE_ID=                 # ID del software registrado ante la DIAN
# DIAN_SOFTWARE_PIN=                # PIN del software registrado ante la DIAN

VITE_APP_NAME="${APP_NAME}"
